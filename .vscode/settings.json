{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.tabSize": 4,
  "editor.detectIndentation": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "eslint.validate": ["javascript"],
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/dist": true,
    "**/__pycache__/**": true,
    "**/*.pyc": true,
    "**/*.egg-info/**": true,
    ".pytest_cache/": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/npm-debug.log": true,
    "**/.env": true,
    "**/.DS_Store": true,
    "**/.idea/": true,
    "**/.idea_modules/": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.egg-info": true,
    ".pytest_cache/": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.egg-info": true
  },
  "cmake.configureOnOpen": false,
  "color-picker.languages": [
    "python",
    "javascript",
    "javascriptreact",
    "typescript"
  ],
  "[json]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
